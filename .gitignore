# ──────────────────────────────────────────────
# Sign Language Recognition — .gitignore
# ──────────────────────────────────────────────

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Virtual environments
.venv/
venv/
env/
.env/
ENV/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Project-specific exclusions ─────────────
# Data — never commit raw or processed videos
data/raw/
data/processed/
data/train/
data/val/
data/test/

# Model weights — large binary files
checkpoints/*.pth
checkpoints/*.pt

# Training outputs
logs/
results/figures/
results/metrics/
results/inference_snapshots/
results/baseline/

# MLflow experiment tracking
mlruns/
mlartifacts/

# Config overrides with real paths
config.yaml

# OS files
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db

# IDE
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Misc
*.log
*.pkl
*.npz
*.npy
*.csv
